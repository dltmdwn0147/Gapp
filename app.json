{
  "expo": {
    "name": "my-school-app",
    "slug": "my-school-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/gnu_ginu.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/gnu_ginu.png",
